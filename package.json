{
  "name": "aidesktopsearch",
  "version": "1.0.0",
  "description": "Local-first desktop search that finds files by meaning and keyword",
  "keywords": [
    "electron",
    "desktop",
    "search",
    "local-first",
    "ai"
  ],
  "homepage": "https://github.com/max-well-house/AIDesktopSearch#readme",
  "bugs": {
    "url": "https://github.com/max-well-house/AIDesktopSearch/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/max-well-house/AIDesktopSearch.git"
  },
  "license": "ISC",
  "author": "maxwell-house",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite --config frontend/vite.config.js",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build --config frontend/vite.config.js",
    "start": "npm run build && electron .",
    "package": "npm run build && electron-builder --dir",
    "package:portable": "npm run build && electron-builder --win portable",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "vite": "^7.1.2",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/material": "^9.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "styled-components": "^6.4.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
